<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%date [%level] %logger{20} - %message%n%xException</pattern>
        </encoder>
    </appender>

    <!-- Application loggers -->
    <logger name="metrics" level="INFO"/>
    <logger name="aws" level="INFO"/>
    <logger name="logic" level="INFO"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
