#!/usr/bin/env bash

BUILD_NUMBER="${BUILD_NUMBER:-DEV}"
set -e

(
    cd cdk
    ./script/ci
)

mkdir -p dist

./sbt --no-conf '; project hq; scalafmtCheckAll; scalafmtSbtCheck; clean; compile; test; Debian / packageBin'
mv hq/target/security-hq_*_all.deb "dist/security-hq-$BUILD_NUMBER.deb"

./sbt --no-conf '; project iamOutdatedCredentials; scalafmtCheckAll; scalafmtSbtCheck; clean; compile; test; assembly'
mv iam-outdated-credentials/target/scala-*/iam-outdated-credentials-assembly-*.jar "dist/iam-outdated-credentials-$BUILD_NUMBER.jar"

# Build the iam-unrecognised-users lambda assembly jar
./sbt --no-conf '; project iamUnrecognisedUsers; scalafmtCheckAll; scalafmtSbtCheck; clean; compile; test; assembly'
mv iam-unrecognised-users/target/scala-*/iam-unrecognised-users.jar "dist/iam-unrecognised-users-$BUILD_NUMBER.jar"
